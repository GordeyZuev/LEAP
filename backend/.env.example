# ============================================================================
# LEAP API - Environment Configuration Example
# ============================================================================
# Copy this file to .env and fill in your values
# Most settings have sensible defaults in config/settings.py
# Only override what you need to change
# ============================================================================

# ============================================================================
# IMPORTANT NOTES
# ============================================================================
# - Do NOT use list syntax like ["item1", "item2"] - it will cause JSON parse errors
# - For list-type settings (CORS, formats), use defaults from code or comma-separated strings
# - For local development, use the minimal configuration below
# - For production, add all security-related settings
# ============================================================================


# ============================================================================
# APP SETTINGS
# ============================================================================

# Debug mode - set to true for local development, false for production
APP_DEBUG=false

# Application timezone (pytz format)
APP_TIMEZONE=Europe/Moscow


# ============================================================================
# SERVER SETTINGS
# ============================================================================

SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Auto-reload on code changes (enable for local development)
SERVER_RELOAD=false

# Number of Uvicorn workers (use 1 for local dev, 4+ for production)
SERVER_WORKERS=4

# CORS settings - DO NOT set these unless needed (defaults are ["*"] which works for dev)
# If you need to override, use comma-separated format like: http://localhost:3000,http://localhost:8080
# LAN dev (UI opened by IP): add each frontend origin, e.g. http://192.168.1.11:3000
# SERVER_CORS_ORIGINS=http://localhost:3000,http://192.168.1.11:3000


# ============================================================================
# DATABASE SETTINGS (PostgreSQL)
# ============================================================================

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_DATABASE=zoom_manager
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_secure_password_here

# Connection pool settings
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10


# ============================================================================
# REDIS SETTINGS
# ============================================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=


# ============================================================================
# CELERY SETTINGS
# ============================================================================

# Broker and backend
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Worker settings
CELERY_WORKER_CONCURRENCY=8

# Task retry settings (optional, defaults are sensible)
# CELERY_TASK_DEFAULT_MAX_RETRIES=3
# CELERY_DOWNLOAD_MAX_RETRIES=3
# CELERY_PROCESSING_MAX_RETRIES=2
# CELERY_UPLOAD_MAX_RETRIES=5


# ============================================================================
# SECURITY SETTINGS
# ============================================================================

# JWT settings - CHANGE SECRET IN PRODUCTION!
SECURITY_JWT_SECRET_KEY=your-super-secret-jwt-key-min-32-characters-change-me-in-production

# Password hashing (BCrypt rounds: 4 for dev, 12 for production)
SECURITY_BCRYPT_ROUNDS=12

# Encryption key for credentials (REQUIRED). Fernet key, base64-encoded 32 bytes.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECURITY_ENCRYPTION_KEY=

# Previous encryption key for rotation (optional). Set when migrating to a new key.
# SECURITY_ENCRYPTION_KEY_OLD=

# Rate limiting (disable for local dev, enable for production)
SECURITY_RATE_LIMIT_ENABLED=true

# ----------------------------------------------------------------------------
# Session cookie security (browser auth flow)
# ----------------------------------------------------------------------------
# Defaults in code: secure=true, samesite=lax, domain unset. Those are safe
# for production; the LOCAL DEV section below overrides them.
#
# - cookie_secure: must be true in production (HTTPS). Browsers drop Secure
#   cookies over HTTP, so plain-localhost dev MUST set this to false.
# - cookie_samesite:
#     lax    — default; works when frontend and API are on the same site.
#     strict — no cross-site requests at all (incl. top-level navs).
#     none   — cross-site allowed; requires secure=true and HTTPS frontend.
# - cookie_domain: leave empty for host-only cookies; set ".example.com" to
#   share the session across subdomains.

# LOCAL DEV — uncomment these when running the API on plain HTTP (make api):
# SECURITY_COOKIE_SECURE=false
# SECURITY_COOKIE_SAMESITE=lax

# PRODUCTION — values live in scripts/vm-init.sh → .env.static, do NOT put them here.

# ----------------------------------------------------------------------------
# CORS — required for the cookie auth flow
# ----------------------------------------------------------------------------
# Wildcards are rejected by browsers when credentials are involved, so the
# frontend origin(s) must be listed explicitly. JSON list format (pydantic-
# settings parses it that way; the comma-separated form below is silently
# treated as a single-element list).
# SERVER_CORS_ORIGINS=["http://localhost:3000"]

# PRODUCTION — set in scripts/vm-init.sh (.env.static) to ["https://${DOMAIN}"].


# ============================================================================
# STORAGE SETTINGS
# ============================================================================

# Storage backend type: LOCAL or S3
STORAGE_TYPE=LOCAL

# ---- LOCAL Storage Configuration ----
# Path to store files locally
STORAGE_LOCAL_PATH=storage

# Optional: Max storage quota in GB (unlimited if not set)
# STORAGE_LOCAL_MAX_SIZE_GB=1000

# ---- S3 Storage Configuration ----
# Only needed if STORAGE_TYPE=S3
#
# Provider examples:
#   AWS S3:               leave STORAGE_S3_ENDPOINT_URL empty, region = us-east-1 etc.
#   Yandex Object Storage: STORAGE_S3_ENDPOINT_URL=https://storage.yandexcloud.net, region=ru-central1
#   MinIO (local dev):     STORAGE_S3_ENDPOINT_URL=http://localhost:9000, any region

# S3 bucket name (required when STORAGE_TYPE=S3)
# STORAGE_S3_BUCKET=leap-platform-storage

# S3 key prefix (folder structure inside bucket); leave empty to write at bucket root
# STORAGE_S3_PREFIX=storage

# AWS region (Yandex Cloud: ru-central1)
# STORAGE_S3_REGION=ru-central1

# Optional: Max S3 storage quota in GB
# STORAGE_S3_MAX_SIZE_GB=5000

# Credentials (Yandex Cloud: Service Account static access key)
# STORAGE_S3_ACCESS_KEY_ID=
# STORAGE_S3_SECRET_ACCESS_KEY=

# Optional: Custom S3 endpoint (for non-AWS S3-compatible providers)
# STORAGE_S3_ENDPOINT_URL=https://storage.yandexcloud.net

# Presigned URL TTL in seconds (used for video streaming to the frontend).
# Range: 60..604800 (1 minute to 7 days). Default: 3600 (1 hour).
# STORAGE_S3_PRESIGN_EXPIRES=3600

# Video/image extension allowlists: ``STORAGE_DEFAULT_VIDEO_FORMATS`` / ``STORAGE_DEFAULT_IMAGE_FORMATS`` in ``config.settings``;
# `StorageSettings.supported_*_formats`); do not set legacy `STORAGE_SUPPORTED_*` vars (ignored).

# ---- Legacy Storage Settings (for backward compatibility) ----
# STORAGE_MAX_UPLOAD_SIZE_MB=5000

# ============================================================================
# LOGGING SETTINGS
# ============================================================================

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOGGING_LEVEL=INFO


# ============================================================================
# MONITORING SETTINGS
# ============================================================================

# Disable for local development
MONITORING_ENABLED=false

# Prometheus metrics endpoint (/metrics). Auto-enabled by docker-compose,
# disable explicitly for local `make api` if you don't want the endpoint mounted.
# MONITORING_PROMETHEUS_ENABLED=true

# Optional: Sentry for error tracking (production only)
# MONITORING_SENTRY_DSN=
# MONITORING_SENTRY_ENVIRONMENT=production

# ---- Loki S3 backend (off-host log durability) ----
# Logs are shipped to Loki, which stores chunks + index in Yandex Object Storage.
# Required in production; not needed for local `make api`.
# LOKI_S3_BUCKET=leap-logs-prod
# LOKI_S3_ACCESS_KEY_ID=
# LOKI_S3_SECRET_ACCESS_KEY=

# ---- Grafana → Postgres read-only role (for the LEAP Overview dashboard) ----
# Required by alembic migration 023 AND by Grafana's LEAP-DB datasource. The
# migration aborts if this is empty in production.
# GRAFANA_RO_PASSWORD=


# ============================================================================
# OAUTH SETTINGS (optional - only if using OAuth)
# ============================================================================

# Base URL for OAuth callbacks
# OAUTH_BASE_URL=http://localhost:8000

# Frontend URL for post-OAuth redirect (where to send user after success/error)
# OAUTH_FRONTEND_REDIRECT_URL=http://localhost:8080

# YouTube OAuth (leave empty if not used)
# OAUTH_YOUTUBE_CLIENT_ID=
# OAUTH_YOUTUBE_CLIENT_SECRET=

# VK OAuth (leave empty if not used)
# OAUTH_VK_CLIENT_ID=
# OAUTH_VK_CLIENT_SECRET=

# Zoom OAuth (leave empty if not used)
# OAUTH_ZOOM_CLIENT_ID=
# OAUTH_ZOOM_CLIENT_SECRET=

# Yandex Disk OAuth — JSON path (default: config/oauth_yandex_disk.json)
# YANDEX_DISK_OAUTH_CONFIG=config/oauth_yandex_disk.json


# ============================================================================
# FEATURE FLAGS (optional - use defaults)
# ============================================================================

# Most features are enabled by default
# Override only if you need to disable something

# FEATURE_AUTO_TRANSCRIPTION=true
# FEATURE_AUTOMATION_ENABLED=true


# ============================================================================
# PROCESSING SETTINGS (optional - use defaults)
# ============================================================================

# Keep temp files for debugging (set to false in production)
# PROCESSING_KEEP_TEMP_FILES=false


# ============================================================================
# AI PROVIDERS (application-level; secrets in config/*_creds.json)
# ============================================================================
# JSON templates: config/examples/*.json.example
#
# Fireworks ASR: operational defaults via FIREWORKS_* (see config/settings.py FireworksSettings).
# Required: config/fireworks_creds.json — {"api_key": "...", "account_id": "..."} (account_id for Batch API).
# FIREWORKS_MODEL=whisper-v3-turbo
# FIREWORKS_VAD_MODEL=whisperx-pyannet
# FIREWORKS_PREPROCESSING=dynamic
# FIREWORKS_TEMPERATURE=0.01

# DeepSeek (topics): DEEPSEEK_* and DEEPSEEK_FIREWORKS_* for fallback endpoint.
# Required: config/deepseek_creds.json {"api_key": "..."}; optional config/deepseek_fireworks_creds.json for fallback.
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_FIREWORKS_MODEL=accounts/fireworks/models/deepseek-v3
# DEEPSEEK_FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# DEEPSEEK_FIREWORKS_COMPLETION_TOKEN_CEILING=4096


# ============================================================================
# YT-DLP SETTINGS (YouTube, VK, Rutube — bypass bot detection)
# ============================================================================
# If YouTube blocks with "Sign in to confirm you're not a bot", use cookies.
# Use ONE of the options below. YTDLP_COOKIES_FILE takes precedence.

# Path to Netscape-format cookies file (recommended for production).
# Export: yt-dlp --cookies-from-browser chrome --cookies cookies.txt
# YTDLP_COOKIES_FILE=/path/to/cookies.txt

# Or: browser name to extract cookies from (requires browser on server).
# YTDLP_COOKIES_FROM_BROWSER=chrome


# ============================================================================
# LEGACY SETTINGS (for backwards compatibility)
# ============================================================================
# Logger (logger.py)
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
ERROR_LOG_FILE=logs/error.log

# Structured JSON sink — Promtail tails this file and ships to Loki.
# When unset the sink is disabled (no JSON file written). docker-compose
# defaults it to /app/logs/structured.json — see backend/docs/guides/MONITORING.md.
# JSON_LOG_FILE=logs/structured.json

# docker-compose only
DB_PASSWORD=your_secure_password_here
