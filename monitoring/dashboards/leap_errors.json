{
  "annotations": {"list": []},
  "description": "Errors essentials — what's breaking, where, for whom. Loki-driven.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {"title": "Drill-down", "type": "dashboards", "tags": ["leap"], "asDropdown": true, "includeVars": false, "keepTime": true}
  ],
  "panels": [
    {"type": "row", "title": "Pulse", "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1}, "collapsed": false, "panels": []},
    {
      "type": "stat",
      "title": "ERRORs (5m)",
      "gridPos": {"x": 0, "y": 1, "w": 12, "h": 4},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"refId": "A", "expr": "sum(count_over_time({app=\"leap\", level=~\"ERROR|CRITICAL\"}[5m]))"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 10}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area"}
    },
    {
      "type": "stat",
      "title": "Distinct affected recordings (1h)",
      "gridPos": {"x": 12, "y": 1, "w": 12, "h": 4},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"refId": "A", "expr": "count(count by (record_extra_recording_id) (count_over_time({app=\"leap\", level=~\"ERROR|CRITICAL\"} | json | record_extra_recording_id != \"\" [1h])))"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 5}, {"color": "red", "value": 25}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none"}
    },

    {"type": "row", "title": "What's breaking", "gridPos": {"x": 0, "y": 5, "w": 24, "h": 1}, "collapsed": false, "panels": []},
    {
      "type": "table",
      "title": "Top exception types (1h)",
      "gridPos": {"x": 0, "y": 6, "w": 12, "h": 9},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"refId": "A", "expr": "topk(15, sum by (exception_class) (count_over_time({app=\"leap\", exception_class!=\"\"}[1h])))", "instant": true, "format": "table"}],
      "transformations": [
        {"id": "organize", "options": {"excludeByName": {"Time": true, "__name__": true}, "renameByName": {"exception_class": "Exception", "Value": "Count (1h)"}}}
      ],
      "fieldConfig": {"defaults": {"custom": {"align": "left"}}, "overrides": [
        {"matcher": {"id": "byName", "options": "Count (1h)"}, "properties": [{"id": "custom.cellOptions", "value": {"type": "color-background", "mode": "gradient"}}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 5}, {"color": "red", "value": 50}]}}]}
      ]}
    },
    {
      "type": "logs",
      "title": "Recent ERRORs",
      "gridPos": {"x": 12, "y": 6, "w": 12, "h": 9},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"refId": "A", "expr": "{app=\"leap\", level=~\"ERROR|CRITICAL\"} | json | line_format \"{{.text}}\""}],
      "options": {"showTime": true, "wrapLogMessage": true, "sortOrder": "Descending", "dedupStrategy": "none", "enableLogDetails": true}
    },

    {"type": "row", "title": "Who's affected", "gridPos": {"x": 0, "y": 15, "w": 24, "h": 1}, "collapsed": false, "panels": []},
    {
      "type": "table",
      "title": "Errors by recording (1h)",
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 9},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"refId": "A", "expr": "topk(10, sum by (record_extra_recording_id) (count_over_time({app=\"leap\", level=~\"ERROR|CRITICAL\"} | json | record_extra_recording_id != \"\" [1h])))", "instant": true, "format": "table"}],
      "transformations": [
        {"id": "organize", "options": {"renameByName": {"record_extra_recording_id": "Recording", "Value": "Errors (1h)"}, "excludeByName": {"Time": true, "__name__": true}}}
      ],
      "fieldConfig": {"defaults": {}, "overrides": [
        {"matcher": {"id": "byName", "options": "Errors (1h)"}, "properties": [{"id": "custom.cellOptions", "value": {"type": "color-background", "mode": "gradient"}}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "yellow", "value": null}, {"color": "red", "value": 10}]}}]}
      ]}
    },
    {
      "type": "table",
      "title": "Errors by user (1h, 8-char id)",
      "gridPos": {"x": 12, "y": 16, "w": 12, "h": 9},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"refId": "A", "expr": "topk(10, sum by (record_extra_user_id) (count_over_time({app=\"leap\", level=~\"ERROR|CRITICAL\"} | json | record_extra_user_id != \"\" [1h])))", "instant": true, "format": "table"}],
      "transformations": [
        {"id": "organize", "options": {"renameByName": {"record_extra_user_id": "User", "Value": "Errors (1h)"}, "excludeByName": {"Time": true, "__name__": true}}}
      ],
      "fieldConfig": {"defaults": {}, "overrides": [
        {"matcher": {"id": "byName", "options": "Errors (1h)"}, "properties": [{"id": "custom.cellOptions", "value": {"type": "color-background", "mode": "gradient"}}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "yellow", "value": null}, {"color": "red", "value": 10}]}}]}
      ]}
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["leap", "errors"],
  "templating": {"list": []},
  "time": {"from": "now-3h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "LEAP Errors & Logs",
  "uid": "leap-errors",
  "version": 2
}
