{
  "annotations": {"list": []},
  "description": "HTTP traffic for the LEAP FastAPI: RED metrics (Rate, Errors, Duration) plus route-level breakdowns. Source: prometheus-fastapi-instrumentator at /metrics under the leap_http_* namespace.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {"title": "Pipeline", "type": "dashboards", "tags": ["leap"], "asDropdown": true, "includeVars": false, "keepTime": true}
  ],
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1},
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Requests / sec (5m)",
      "gridPos": {"x": 0, "y": 1, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum(rate(leap_http_requests_total[5m]))"}
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area"},
      "fieldConfig": {"defaults": {"unit": "reqps", "decimals": 2, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}}
    },
    {
      "type": "stat",
      "title": "Error rate (5xx, 5m)",
      "gridPos": {"x": 6, "y": 1, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "100 * sum(rate(leap_http_requests_total{status=~\"5..\"}[5m])) / clamp_min(sum(rate(leap_http_requests_total[5m])), 1e-9)"}
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area"},
      "fieldConfig": {"defaults": {"unit": "percent", "decimals": 2, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 5}]}}}
    },
    {
      "type": "stat",
      "title": "p95 latency (5m)",
      "gridPos": {"x": 12, "y": 1, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "histogram_quantile(0.95, sum by (le) (rate(leap_http_request_duration_seconds_bucket[5m])))"}
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area"},
      "fieldConfig": {"defaults": {"unit": "s", "decimals": 3, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.5}, {"color": "red", "value": 2}]}}}
    },
    {
      "type": "stat",
      "title": "In-flight requests",
      "gridPos": {"x": 18, "y": 1, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum(leap_http_requests_inprogress)"}
      ],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area"},
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0}}
    },
    {
      "type": "row",
      "title": "Latency & throughput",
      "gridPos": {"x": 0, "y": 5, "w": 24, "h": 1},
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Latency percentiles (s)",
      "gridPos": {"x": 0, "y": 6, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "histogram_quantile(0.50, sum by (le) (rate(leap_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p50"},
        {"refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(leap_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p95"},
        {"refId": "C", "expr": "histogram_quantile(0.99, sum by (le) (rate(leap_http_request_duration_seconds_bucket[5m])))", "legendFormat": "p99"}
      ],
      "fieldConfig": {"defaults": {"unit": "s", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10}}},
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}}
    },
    {
      "type": "timeseries",
      "title": "Requests / sec by status class",
      "gridPos": {"x": 12, "y": 6, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum by (status) (label_replace(rate(leap_http_requests_total[5m]), \"status\", \"${1}xx\", \"status\", \"(.).*\"))", "legendFormat": "{{status}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 30, "stacking": {"mode": "normal"}}}, "overrides": [
        {"matcher": {"id": "byName", "options": "2xx"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "green"}}]},
        {"matcher": {"id": "byName", "options": "3xx"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "blue"}}]},
        {"matcher": {"id": "byName", "options": "4xx"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "yellow"}}]},
        {"matcher": {"id": "byName", "options": "5xx"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]}
      ]},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean"]}}
    },
    {
      "type": "row",
      "title": "Per-route",
      "gridPos": {"x": 0, "y": 14, "w": 24, "h": 1},
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Top 10 routes by RPS",
      "gridPos": {"x": 0, "y": 15, "w": 12, "h": 9},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "topk(10, sum by (handler) (rate(leap_http_requests_total[5m])))", "legendFormat": "{{handler}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10}}},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max"]}}
    },
    {
      "type": "table",
      "title": "Top 10 slowest routes (p95)",
      "gridPos": {"x": 12, "y": 15, "w": 12, "h": 9},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "topk(10, histogram_quantile(0.95, sum by (handler, le) (rate(leap_http_request_duration_seconds_bucket[5m]))))", "instant": true, "format": "table"}
      ],
      "transformations": [
        {"id": "organize", "options": {"excludeByName": {"Time": true, "job": true, "service": true, "__name__": true}, "indexByName": {"handler": 0, "Value": 1}, "renameByName": {"handler": "Route", "Value": "p95 (s)"}}}
      ],
      "fieldConfig": {"defaults": {"unit": "s", "decimals": 3}, "overrides": [
        {"matcher": {"id": "byName", "options": "p95 (s)"}, "properties": [{"id": "custom.cellOptions", "value": {"type": "color-background", "mode": "gradient"}}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.5}, {"color": "red", "value": 2}]}}]}
      ]}
    },
    {
      "type": "row",
      "title": "Errors",
      "gridPos": {"x": 0, "y": 24, "w": 24, "h": 1},
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "5xx errors by route",
      "gridPos": {"x": 0, "y": 25, "w": 12, "h": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"refId": "A", "expr": "sum by (handler) (rate(leap_http_requests_total{status=~\"5..\"}[5m]))", "legendFormat": "{{handler}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"drawStyle": "bars", "fillOpacity": 70, "stacking": {"mode": "normal"}}}},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["sum"]}}
    },
    {
      "type": "logs",
      "title": "Recent 5xx (logs)",
      "gridPos": {"x": 12, "y": 25, "w": 12, "h": 8},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [
        {"refId": "A", "expr": "{app=\"leap\", module=\"http.access\", status_code=~\"5..\"} | json | line_format \"{{.text}}\""}
      ],
      "options": {"showTime": true, "wrapLogMessage": true, "sortOrder": "Descending", "dedupStrategy": "none", "enableLogDetails": true}
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["leap", "api"],
  "templating": {"list": []},
  "time": {"from": "now-3h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "LEAP API",
  "uid": "leap-api",
  "version": 1
}
