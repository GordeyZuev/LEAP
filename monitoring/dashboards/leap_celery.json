{
  "annotations": {"list": []},
  "description": "Celery worker + queue essentials: is anything stuck, what fails. Sources: danihodovic/celery-exporter + custom leap_queue_oldest_task_age_seconds + Loki failure logs.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {"title": "Drill-down", "type": "dashboards", "tags": ["leap"], "asDropdown": true, "includeVars": false, "keepTime": true}
  ],
  "panels": [
    {"type": "row", "title": "Pulse", "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1}, "collapsed": false, "panels": []},
    {
      "type": "stat",
      "title": "Failure rate (5m)",
      "gridPos": {"x": 0, "y": 1, "w": 8, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "100 * sum(rate(celery_task_failed_total[5m])) / clamp_min(sum(rate(celery_task_received_total[5m])), 1e-9)"}],
      "fieldConfig": {"defaults": {"unit": "percent", "decimals": 2, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 5}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area"}
    },
    {
      "type": "stat",
      "title": "Active workers",
      "gridPos": {"x": 8, "y": 1, "w": 8, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "count(celery_worker_up == 1)"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none"}
    },
    {
      "type": "stat",
      "title": "Pending tasks (all queues)",
      "gridPos": {"x": 16, "y": 1, "w": 8, "h": 4},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "sum(celery_queue_length)"}],
      "fieldConfig": {"defaults": {"unit": "short", "decimals": 0, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 50}, {"color": "red", "value": 200}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area"}
    },

    {"type": "row", "title": "Queues", "gridPos": {"x": 0, "y": 5, "w": 24, "h": 1}, "collapsed": false, "panels": []},
    {
      "type": "timeseries",
      "title": "Queue depth per queue",
      "gridPos": {"x": 0, "y": 6, "w": 12, "h": 9},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "celery_queue_length", "legendFormat": "{{queue_name}}"}],
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 25}}},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"]}}
    },
    {
      "type": "timeseries",
      "title": "Oldest task age per queue",
      "gridPos": {"x": 12, "y": 6, "w": 12, "h": 9},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "leap_queue_oldest_task_age_seconds", "legendFormat": "{{queue}}"}],
      "fieldConfig": {"defaults": {"unit": "s", "decimals": 0, "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 300}, {"color": "red", "value": 900}]}, "custom": {"drawStyle": "line", "fillOpacity": 30, "thresholdsStyle": {"mode": "area"}}}},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["max", "lastNotNull"]}}
    },

    {"type": "row", "title": "Failures", "gridPos": {"x": 0, "y": 15, "w": 24, "h": 1}, "collapsed": false, "panels": []},
    {
      "type": "timeseries",
      "title": "Failures by task name",
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 9},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"refId": "A", "expr": "sum by (name) (rate(celery_task_failed_total[5m])) > 0", "legendFormat": "{{name}}"}],
      "fieldConfig": {"defaults": {"unit": "ops", "custom": {"drawStyle": "bars", "fillOpacity": 70, "stacking": {"mode": "normal"}}}},
      "options": {"legend": {"displayMode": "table", "placement": "right", "calcs": ["sum"]}}
    },
    {
      "type": "logs",
      "title": "Recent task failures",
      "gridPos": {"x": 12, "y": 16, "w": 12, "h": 9},
      "datasource": {"type": "loki", "uid": "loki"},
      "targets": [{"refId": "A", "expr": "{app=\"leap\", task_state=\"FAILURE\"} | json | line_format \"{{.text}}\""}],
      "options": {"showTime": true, "wrapLogMessage": true, "sortOrder": "Descending", "dedupStrategy": "none", "enableLogDetails": true}
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["leap", "celery"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "LEAP Celery",
  "uid": "leap-celery",
  "version": 1
}
